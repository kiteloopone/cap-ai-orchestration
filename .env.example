# Copy this file to .env and fill it with values from your SAP AI Core service key.
# Keep .env private. It is already ignored by git.

# SAP AI SDK reads the AI Core service credentials from this JSON string.
# Example shape only. Replace the values with your real service key.
AICORE_SERVICE_KEY={"clientid":"<client-id>","clientsecret":"<client-secret>","url":"<auth-url>","serviceurls":{"AI_API_URL":"<ai-api-url>"}}

# Resource group used for the orchestration deployment.
AI_RESOURCE_GROUP=<resource-group-id>

# Optional: use a specific orchestration deployment instead of resolving by resource group.
# AI_ORCHESTRATION_DEPLOYMENT_ID=<deployment-id>

# Optional: use an orchestration configuration created in SAP AI Launchpad.
# Use either the config ID, or the scenario/name/version triplet.
# The current CAP request sends the user prompt as {{?user_query}}.
# AI_ORCHESTRATION_CONFIG_ID=<configuration-id>
# AI_ORCHESTRATION_CONFIG_SCENARIO=<scenario-id>
# AI_ORCHESTRATION_CONFIG_NAME=<configuration-name>
# AI_ORCHESTRATION_CONFIG_VERSION=<configuration-version>

# Optional: cheapest practical model for testing, if available in SAP AI Core / Generative AI Hub.
AI_MODEL_NAME=gpt-4.1-nano
