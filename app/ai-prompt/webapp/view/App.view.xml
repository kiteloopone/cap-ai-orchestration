<mvc:View
  controllerName="cap-ai-orchestration.ai-prompt.controller.App"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:u="sap.ui.unified">
  <App class="aiPromptApp">
    <Page
      id="promptPage"
      title="{i18n>appTitle}"
      showHeader="true"
      enableScrolling="true"
      class="aiPromptPage">
      <content>
        <VBox class="aiPromptContent" width="100%">
          <VBox class="aiPromptInputBlock aiPromptSurface" width="100%">
            <Label text="{i18n>promptLabel}" labelFor="promptInput" class="sapUiTinyMarginBottom" />
            <TextArea
              id="promptInput"
              value="{view>/prompt}"
              rows="6"
              width="100%"
              enabled="{= !${view>/busy} }"
              placeholder="{i18n>promptPlaceholder}" />
            <OverflowToolbar class="aiPromptToolbar">
              <ToolbarSpacer />
              <Button
                type="Emphasized"
                icon="sap-icon://paper-plane"
                text="{i18n>sendButton}"
                busy="{view>/busy}"
                busyIndicatorDelay="0"
                enabled="{= !${view>/busy} &amp;&amp; !!${view>/prompt} }"
                press=".onSubmit" />
            </OverflowToolbar>
          </VBox>

          <MessageStrip
            class="sapUiSmallMarginTop"
            text="{view>/error}"
            type="Error"
            showIcon="true"
            visible="{= !!${view>/error} }" />

          <VBox class="aiPromptDocumentBlock aiPromptSurface" width="100%">
            <Toolbar class="aiPromptSectionToolbar">
              <Title text="{i18n>documentsTitle}" level="H2" />
              <ToolbarSpacer />
              <ObjectStatus
                text="{= ${view>/documents}.length }"
                state="Information" />
            </Toolbar>
            <HBox class="aiPromptDocumentToolbar" width="100%" alignItems="Center">
              <u:FileUploader
                id="documentUploader"
                width="100%"
                fileType="pdf"
                mimeType="application/pdf"
                sameFilenameAllowed="true"
                buttonText="{i18n>choosePdfButton}"
                placeholder="{i18n>choosePdfPlaceholder}"
                change=".onDocumentFileChange" />
              <Button
                type="Emphasized"
                icon="sap-icon://upload"
                text="{i18n>uploadProcessButton}"
                busy="{view>/documentBusy}"
                busyIndicatorDelay="0"
                enabled="{= !${view>/documentBusy} &amp;&amp; !!${view>/selectedFileName} }"
                press=".onUploadAndProcessDocument" />
            </HBox>
            <MessageStrip
              class="sapUiTinyMarginTop"
              text="{view>/documentError}"
              type="Error"
              showIcon="true"
              visible="{= !!${view>/documentError} }" />
            <Table
              class="aiPromptTable sapUiSmallMarginTop"
              items="{view>/documents}"
              alternateRowColors="true"
              growing="true"
              growingThreshold="8"
              noDataText="{i18n>noDocumentsText}">
              <columns>
                <Column><Text text="{i18n>documentNameColumn}" /></Column>
                <Column width="8rem"><Text text="{i18n>documentStatusColumn}" /></Column>
                <Column><Text text="{i18n>documentResultColumn}" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{view>fileName}" wrapping="true" />
                    <ObjectStatus text="{view>status}" state="{path: 'view>status', formatter: '.formatDocumentStatusState'}" />
                    <Text text="{view>resultText}" wrapping="true" maxLines="4" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>

            <Title
              text="{i18n>invoiceAttributesTitle}"
              level="H3"
              class="aiPromptSubSectionTitle" />
            <Table
              class="aiPromptTable sapUiTinyMarginTop"
              items="{view>/invoiceDocumentAttributes}"
              alternateRowColors="true"
              growing="true"
              growingThreshold="8"
              noDataText="{i18n>noInvoiceAttributesText}">
              <columns>
                <Column><Text text="{i18n>attributeDocumentColumn}" /></Column>
                <Column><Text text="{i18n>attributeSupplierColumn}" /></Column>
                <Column width="9rem"><Text text="{i18n>attributeInvoiceNumberColumn}" /></Column>
                <Column width="8rem"><Text text="{i18n>attributeInvoiceDateColumn}" /></Column>
                <Column width="8rem"><Text text="{i18n>attributeDueDateColumn}" /></Column>
                <Column width="9rem" hAlign="End"><Text text="{i18n>attributeTotalColumn}" /></Column>
                <Column><Text text="{i18n>attributeSummaryColumn}" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{view>fileName}" wrapping="true" />
                    <Text text="{view>supplierName}" wrapping="true" />
                    <Text text="{view>invoiceNumber}" wrapping="true" />
                    <Text text="{view>invoiceDate}" />
                    <Text text="{view>dueDate}" />
                    <Text
                      text="{parts: [{path: 'view>totalAmount'}, {path: 'view>currency'}], formatter: '.formatAmount'}"
                      textAlign="End"
                      width="100%" />
                    <Text text="{view>summary}" wrapping="true" maxLines="3" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>

          <VBox class="aiPromptChatBlock aiPromptSurface" width="100%" visible="{= ${view>/messages}.length > 0 }">
            <Title text="{i18n>chatTitle}" level="H2" class="aiPromptChatTitle" />
            <List
              items="{view>/messages}"
              showSeparators="Inner"
              mode="None"
              class="aiPromptChatList">
              <CustomListItem>
                <VBox class="aiPromptMessage" width="100%">
                  <VBox class="aiPromptRequest" width="100%">
                    <Label text="{i18n>requestTitle}" />
                    <FormattedText htmlText="{view>requestHtml}" class="aiPromptMessageText" />
                  </VBox>
                  <VBox class="aiPromptResponse" width="100%">
                    <Label text="{i18n>responseTitle}" />
                    <BusyIndicator
                      size="1.5rem"
                      visible="{view>pending}" />
                    <FormattedText
                      htmlText="{view>responseHtml}"
                      visible="{= !!${view>responseHtml} }"
                      class="aiPromptMessageText" />
                    <MessageStrip
                      text="{view>error}"
                      type="Error"
                      showIcon="true"
                      visible="{= !!${view>error} }" />
                  </VBox>
                </VBox>
              </CustomListItem>
            </List>
          </VBox>
        </VBox>
      </content>
    </Page>
  </App>
</mvc:View>
